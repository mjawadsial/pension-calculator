{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.php": { "runtime": "vercel-php@0.7.2" }
  },
  "routes": [
    { "src": "/build/assets/(.*)", "dest": "/public/build/assets/$1" },
    { "src": "/build/manifest.json", "dest": "/public/build/manifest.json" },
    { "src": "/fonts/(.*)", "dest": "/public/fonts/$1" },
    { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "outputDirectory": "public",
  "buildCommand": "npm run build"
}